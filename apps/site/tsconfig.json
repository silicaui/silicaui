{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@wizeworks/silicaui-react": ["../../packages/silicaui-react/src/index.ts"],
      "@wizeworks/silicaui-html": ["../../packages/silicaui-html/src/index.ts"],
      "@wizeworks/silicaui-html/blocks": ["../../packages/silicaui-html/src/blocks/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
