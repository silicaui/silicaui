{
  "name": "silicaui",
  "version": "0.0.0",
  "private": true,
  "description": "Silica UI \u2014 a daisyUI-style CSS system + shadcn-style React components for Tailwind CSS v4.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "designer": "pnpm --filter @wizeworks/silicaui-builder harness",
    "site:dev": "pnpm --filter @wizeworks/silicaui-site dev",
    "site:build": "pnpm --filter @wizeworks/silicaui-site build",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "verify:packaging": "node scripts/verify-packaging.mjs",
    "verify": "pnpm verify:packaging && pnpm -r verify && pnpm --filter @wizeworks/silicaui-html golden",
    "lint": "node eslint-rules/verify-rules.mjs && eslint .",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-ssr-friendly": "^1",
    "globals": "^17.7.0",
    "typescript-eslint": "^8"
  }
}
