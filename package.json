{
  "name": "silicaui",
  "version": "0.0.0",
  "private": true,
  "description": "Silica UI — a daisyUI-style CSS system + shadcn-style React components for Tailwind CSS v4.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "designer": "pnpm --filter @wizeworks/silicaui-builder harness",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
