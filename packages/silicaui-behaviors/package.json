{
  "name": "@wizeworks/silicaui-behaviors",
  "version": "0.5.0",
  "description": "Silica UI's framework-agnostic runtime for the behavior marker contract — scans data-sui-* markers and wires interactivity for any host that renders plain markup.",
  "type": "module",
  "license": "MIT",
  "author": "WizeWorks",
  "repository": {
    "type": "git",
    "url": "https://github.com/silicaui/silicaui.git",
    "directory": "packages/silicaui-behaviors"
  },
  "homepage": "https://silicaui.com",
  "bugs": "https://github.com/silicaui/silicaui/issues",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "verify": "node verify.mjs && node verify-interactive.mjs"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "design-system",
    "behaviors",
    "runtime",
    "vanilla",
    "silica"
  ]
}
