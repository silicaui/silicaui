    "verify:layering": "node scripts/verify-layering.mjs",
    "verify:field-border": "node scripts/verify-field-border.mjs",
    "verify:icon-sizing": "node scripts/verify-icon-sizing.mjs",
    "verify:size-scale": "node scripts/verify-size-scale.mjs",
    "verify:variant-scale": "node scripts/verify-variant-scale.mjs",
    "verify:readable-ink": "node scripts/verify-readable-ink.mjs"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.3.0"
