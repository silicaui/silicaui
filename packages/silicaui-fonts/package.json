{
  "name": "@wizeworks/silicaui-fonts",
  "version": "0.16.0",
  "description": "Silica UI fonts — publish-time Google Fonts self-hosting for sites built with @wizeworks/silicaui-builder.",
  "type": "module",
  "license": "MIT",
  "author": "WizeWorks",
  "repository": {
    "type": "git",
    "url": "https://github.com/silicaui/silicaui.git",
    "directory": "packages/silicaui-fonts"
  },
  "homepage": "https://silicaui.com",
  "bugs": "https://github.com/silicaui/silicaui/issues",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "verify": "node verify.mjs"
  },
  "peerDependencies": {
    "@wizeworks/silicaui-html": ">=0.0.0"
  },
  "devDependencies": {
    "@wizeworks/silicaui-html": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "fonts",
    "google-fonts",
    "self-hosting",
    "design-system",
    "silica"
  ]
}
