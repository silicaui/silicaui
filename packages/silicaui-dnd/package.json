{
  "name": "silicaui-dnd",
  "version": "0.1.0",
  "description": "Silica UI drag-and-drop — dnd-kit wrapped with a Silica-styled SortableList plus the low-level primitives.",
  "type": "module",
  "license": "MIT",
  "author": "WizeWorks",
  "repository": {
    "type": "git",
    "url": "https://github.com/wize-works/silicaui.git",
    "directory": "packages/silicaui-dnd"
  },
  "homepage": "https://github.com/wize-works/silicaui/tree/main/packages/silicaui-dnd#readme",
  "bugs": "https://github.com/wize-works/silicaui/issues",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "silicaui-react": ">=0.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "silicaui-react": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "react",
    "drag-and-drop",
    "sortable",
    "dnd-kit",
    "design-system",
    "silica"
  ]
}
