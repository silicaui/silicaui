{
  "name": "@wizeworks/silicaui-demos",
  "version": "0.0.0",
  "private": true,
  "description": "Live component demos shared by the playground and silicaui.com's docs — not published to npm.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./meta": {
      "types": "./dist/meta.d.ts",
      "import": "./dist/meta.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@wizeworks/silicaui-charts": "workspace:*",
    "@wizeworks/silicaui-dnd": "workspace:*",
    "@wizeworks/silicaui-editor": "workspace:*",
    "@wizeworks/silicaui-panels": "workspace:*",
    "@wizeworks/silicaui-react": "workspace:*",
    "@wizeworks/silicaui-table": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
